import json
from pathlib import Path

import pandas as pd
import pytest


def _minimal_cfg(tmp_path: Path) -> dict:
    """Return a minimal config dict that satisfies main.py validation."""
    return {
        "data": {"target": "target"},
        "split": {"test_size": 0.2, "val_size": 0.25, "random_state": 123, "stratify": False},
        "artifacts": {"dir": str(tmp_path / "artifacts")},
        "logging": {"level": "INFO", "dir": str(tmp_path / "logs"), "file": "main.log"},
    }


def test_run_pipeline_happy_path_writes_artifacts(tmp_path, monkeypatch):
    """
    Validates that main.py orchestrates:
      load -> clean -> validate -> split -> features -> train -> evaluate -> infer
    and writes artifacts: validation_report.json, metrics.json, predictions.csv.
    """
    from src import main as main_mod
    from src import load_data, clean_data, validate, features, train, evaluate, infer

    cfg = _minimal_cfg(tmp_path)
    main_mod.validate_config(cfg)

    # --- Arrange: stub out module functions ---
    call_order = []

    # Load returns a DataFrame with a target column
    def fake_load(cfg_in, logger=None):
        call_order.append("load")
        return pd.DataFrame(
            {
                "f1": [1, 2, 3, 4, 5],
                "f2": [10, 20, 30, 40, 50],
                "target": [0, 1, 0, 1, 0],
            }
        )

    def fake_clean(df, cfg_in, logger=None):
        call_order.append("clean")
        # pretend cleaning doesn't drop rows
        return df.copy()

    def fake_validate(df, cfg_in, logger=None):
        call_order.append("validate")
        return {"ok": True, "n_rows": int(df.shape[0]), "n_cols": int(df.shape[1])}

    # Features returns an "unfitted recipe" object (can be anything, main passes it through)
    class DummyPreprocessor:
        pass

    def fake_features(X_train, cfg_in, logger=None):
        call_order.append("features")
        assert "target" not in X_train.columns  # target should have been separated before features
        return DummyPreprocessor()

    # Train returns a model with predict()
    class DummyModel:
        def predict(self, X):
            # simple deterministic output
            return [0] * len(X)

    def fake_train(X_train, y_train, preprocessor, cfg_in, logger=None):
        call_order.append("train")
        assert isinstance(preprocessor, DummyPreprocessor)
        assert len(X_train) == len(y_train)
        return {"model": DummyModel(), "model_path": str(tmp_path / "artifacts" / "dummy_model.pkl")}

    def fake_evaluate(model, X_val, y_val, cfg_in, logger=None):
        call_order.append("evaluate")
        assert hasattr(model, "predict")
        # return metrics dict
        return {"accuracy": 0.5}

    def fake_infer(model, X_test, cfg_in, logger=None):
        call_order.append("infer")
        return model.predict(X_test)

    # Monkeypatch onto the imported src.* modules
    monkeypatch.setattr(load_data, "load_data", fake_load, raising=False)
    monkeypatch.setattr(clean_data, "clean_data", fake_clean, raising=False)
    monkeypatch.setattr(validate, "validate_dataframe", fake_validate, raising=False)
    monkeypatch.setattr(features, "build_preprocessor", fake_features, raising=False)
    monkeypatch.setattr(train, "train_model", fake_train, raising=False)
    monkeypatch.setattr(evaluate, "evaluate_model", fake_evaluate, raising=False)
    monkeypatch.setattr(infer, "predict", fake_infer, raising=False)

    # Use a simple logger to avoid writing logs during test
    import logging
    logger = logging.getLogger("test-logger")
    logger.handlers.clear()
    logger.addHandler(logging.NullHandler())
    logger.setLevel(logging.INFO)

    # --- Act ---
    run_id = "testrun"
    summary = main_mod.run_pipeline(cfg, logger, run_id)

    # --- Assert: step order and summary keys ---
    assert call_order == ["load", "clean", "validate", "features", "train", "evaluate", "infer"]

    assert summary["run_id"] == run_id
    assert "metrics" in summary
    assert summary["metrics"]["accuracy"] == 0.5

    art_dir = Path(cfg["artifacts"]["dir"])
    validation_path = art_dir / f"{run_id}__validation_report.json"
    metrics_path = art_dir / f"{run_id}__metrics.json"
    preds_path = art_dir / f"{run_id}__predictions.csv"

    assert validation_path.exists()
    assert metrics_path.exists()
    assert preds_path.exists()

    # Validate artifacts content
    with validation_path.open("r", encoding="utf-8") as f:
        report = json.load(f)
    assert report["ok"] is True

    with metrics_path.open("r", encoding="utf-8") as f:
        metrics = json.load(f)
    assert metrics["accuracy"] == 0.5

    preds_df = pd.read_csv(preds_path)
    assert "prediction" in preds_df.columns
    assert len(preds_df) > 0


def test_run_pipeline_raises_if_target_missing(tmp_path, monkeypatch):
    """If the cleaned dataframe lacks the target column, main.py should fail fast."""
    from src import main as main_mod
    from src import load_data, clean_data, validate, features, train, evaluate, infer

    cfg = _minimal_cfg(tmp_path)
    main_mod.validate_config(cfg)

    def fake_load(cfg_in, logger=None):
        return pd.DataFrame({"f1": [1, 2, 3], "f2": [10, 20, 30], "target": [0, 1, 0]})

    # Cleaning step drops the target (bug)
    def fake_clean(df, cfg_in, logger=None):
        return df.drop(columns=["target"])

    def fake_validate(df, cfg_in, logger=None):
        return {"ok": True}

    # Stub the remaining functions (won't be reached, but keep imports safe)
    monkeypatch.setattr(load_data, "load_data", fake_load, raising=False)
    monkeypatch.setattr(clean_data, "clean_data", fake_clean, raising=False)
    monkeypatch.setattr(validate, "validate_dataframe", fake_validate, raising=False)
    monkeypatch.setattr(features, "build_preprocessor", lambda *a, **k: None, raising=False)
    monkeypatch.setattr(train, "train_model", lambda *a, **k: None, raising=False)
    monkeypatch.setattr(evaluate, "evaluate_model", lambda *a, **k: None, raising=False)
    monkeypatch.setattr(infer, "predict", lambda *a, **k: None, raising=False)

    import logging
    logger = logging.getLogger("test-logger-2")
    logger.handlers.clear()
    logger.addHandler(logging.NullHandler())
    logger.setLevel(logging.INFO)

    with pytest.raises(Exception) as excinfo:
        main_mod.run_pipeline(cfg, logger, run_id="testrun")

    # We don't match exact message to keep it resilient, but ensure it's clearly a pipeline failure
    assert "Target" in str(excinfo.value) or "target" in str(excinfo.value)